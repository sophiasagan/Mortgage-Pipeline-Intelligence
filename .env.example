# ─── Mortgage Pipeline Intelligence — environment template ──────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# ── Anthropic (required for action_generator.py) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── SendGrid (required for daily digest email) ────────────────────────────
SENDGRID_API_KEY=SG....
DIGEST_FROM_EMAIL=noreply@your-cu.org     # must be a verified SendGrid sender
DIGEST_TO_EMAIL=pipeline-team@your-cu.org # comma-separate for multiple recipients

# ── Pipeline config ───────────────────────────────────────────────────────
AT_RISK_THRESHOLD=0.65    # loans below this close probability get actioned

# ── CORS / deployment ─────────────────────────────────────────────────────
# Set on Railway so the API accepts requests from your Vercel frontend.
# Use your exact Vercel production URL (no trailing slash).
FRONTEND_URL=https://your-app.vercel.app

# ── Frontend (set in Vercel dashboard, NOT in this file) ──────────────────
# Only needed if you want the frontend to call Railway directly,
# bypassing the vercel.json rewrite.  Leave blank to use the rewrite.
# VITE_API_URL=https://your-app.up.railway.app
