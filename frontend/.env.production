# Production API URL — set this in the Vercel dashboard instead of here.
# Vercel bakes VITE_* variables into the bundle at build time.
# Go to: Vercel project → Settings → Environment Variables → add:
#   VITE_API_URL = https://your-app.up.railway.app
#
# This file is a reminder only; the real value must come from Vercel's UI.
VITE_API_URL=
